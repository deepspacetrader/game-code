import React, { useState, useEffect, useCallback, useMemo } from 'react';
import { useMarketplace } from '../context/MarketplaceContext';
import { useUI } from '../context/UIContext';
import './Enemy.scss';

const Enemy = ({ enemyData, onEncounterEnd }) => {
    // Get context values
    const {
        inventory = [],
        addToInventory,
        credits = 0,
        updateCredits = () => {},
    } = useMarketplace();

    const { uiTier = 'medium', improvedUILevel } = useUI();

    // Calculate UI scaling factors based on UI Level
    const uiScaling = useMemo(() => {
        // Base scaling values (1.0 means no change)
        let scale = 1.0;
        let opacity = 1.0;
        let animationSpeed = 1.0;
        let fontSize = 1.0;

        // Scale down UI elements at higher levels for better performance
        if (improvedUILevel > 1000) {
            scale = Math.max(0.7, 1.0 - (improvedUILevel - 1000) * 0.0002);
            fontSize = Math.max(0.8, 1.0 - (improvedUILevel - 1000) * 0.0001);
        }

        // Slightly reduce opacity at very high levels for a more subtle UI
        if (improvedUILevel > 2000)
            opacity = Math.max(0.8, 1.0 - (improvedUILevel - 2000) * 0.0001);

        // Speed up animations at higher levels
        if (improvedUILevel > 500)
            animationSpeed = Math.min(2.0, 1.0 + (improvedUILevel - 500) * 0.0005);

        // Add UI tier specific bonuses
        if (uiTier === 'expert' || uiTier === 'master' || uiTier === 'grandmaster') {
            opacity = Math.min(1.0, opacity + 0.1);
        }

        return {
            scale,
            opacity,
            animationSpeed,
            fontSize,
            uiTier,
        };
    }, [improvedUILevel, uiTier]);

    // Track encounter state
    const [encounterActive, setEncounterActive] = useState(false);
    const [playerTurn, setPlayerTurn] = useState(true);
    const [battleLog, setBattleLog] = useState([]);
    const [escapeAttempts, setEscapeAttempts] = useState(0);
    const [bribeAmount, setBribeAmount] = useState(0);
    const [hackProgress, setHackProgress] = useState(0);

    // Enemy state with default values
    const [enemy, setEnemy] = useState({
        name: 'Unknown Threat',
        rank: 'D',
        health: 100,
        maxHealth: 100,
        damage: 10,
        homeGalaxy: 'Unknown',
        language: 'EN',
        credits: 0,
        statusEffects: [],
        isHostile: true,
        isMarketPolice: false,
        reason: 'random_encounter',
    });

    // Helper functions
    const addBattleLog = useCallback((message) => {
        setBattleLog((prev) => [...prev.slice(-9), message]);
    }, []);

    const calculateBribeAmount = useCallback((rank) => {
        const baseAmount =
            {
                S: 10000,
                A: 5000,
                B: 2000,
                C: 1000,
                D: 500,
                default: 1000,
            }[rank] || 1000;

        return Math.floor(baseAmount * (0.8 + Math.random() * 0.4));
    }, []);

    const checkEncounterConditions = useCallback(() => {
        const quantumProcessors = inventory.filter((item) => item.name === 'Quantum Processor');
        const hasIllegalUI =
            improvedUILevel > 1000 &&
            inventory.some((item) => item.isIllegal && item.name !== 'Quantum Processor');

        if (quantumProcessors.length >= 5) return 'quantum_processor_limit';
        if (hasIllegalUI) return 'illegal_ui_increase';
        if (Math.random() < 0.05 && quantumProcessors.length > 0) return 'random_inspection';

        return null;
    }, [inventory, improvedUILevel]);

    // Trigger market police encounter
    const triggerMarketPoliceEncounter = useCallback(
        (reason) => {
            // Determine rank and base stats
            const rank = ['D', 'C', 'B', 'A', 'S'][Math.floor(Math.random() * 5)];
            const baseHealth = {
                S: 500,
                A: 300,
                B: 200,
                C: 150,
                D: 100,
            }[rank] || 100;

            // Create market police enemy with different stats based on reason
            let marketPolice = {
                name: `Market Police ${rank}-Rank Enforcer`,
                rank,
                health: baseHealth,
                maxHealth: baseHealth,
                damage: Math.floor(baseHealth * 0.2),
                homeGalaxy: 'Central Authority',
                language: 'EN',
                credits: 0,
                statusEffects: ['Shielded', 'Armored'],
                isHostile: true,
                isMarketPolice: true,
                reason: reason,
            };

            // Adjust stats based on encounter reason
            switch (reason) {
                case 'quantum_processor_limit':
                    marketPolice = {
                        ...marketPolice,
                        name: `Quantum Regulation Unit (${rank}-Rank)`,
                        health: Math.floor(baseHealth * 1.5),
                        damage: Math.floor(baseHealth * 0.3),
                        statusEffects: ['Quantum Dampening', 'Reinforced Armor'],
                    };
                    break;

                case 'illegal_ui_increase':
                    marketPolice = {
                        ...marketPolice,
                        name: `Compliance Officer (${rank}-Rank)`,
                        health: Math.floor(baseHealth * 1.2),
                        damage: Math.floor(baseHealth * 0.15),
                        statusEffects: ['Lawful Presence', 'System Scan'],
                    };
                    break;

                case 'random_inspection':
                default:
                    marketPolice = {
                        ...marketPolice,
                        name: `Market Inspector (${rank}-Rank)`,
                        health: Math.floor(baseHealth * 0.9),
                        damage: Math.floor(baseHealth * 0.1),
                        credits: 200,
                        statusEffects: ['Scanning', 'Alert']
                    };
                    break;
            }

            // Update enemy state
            setEnemy(marketPolice);
            setEncounterActive(true);
            setPlayerTurn(true);
            setBattleLog([`${marketPolice.name} has detected suspicious activity!`]);
            setEscapeAttempts(0);

            // Calculate initial bribe amount
            const bribe = calculateBribeAmount(rank);
            setBribeAmount(bribe);
        },
        [calculateBribeAmount]
    );

    // Handle enemy turn
    const enemyTurn = useCallback(() => {
        if (!enemy.isHostile || enemy.health <= 0 || !encounterActive) {
            setPlayerTurn(true);
            return;
        }

        // Simple AI for enemy actions
        const action = Math.random();

        if (action < 0.7) {
            // 70% chance to attack
            const damage = Math.floor(enemy.damage * (0.8 + Math.random() * 0.4));
            addBattleLog(`${enemy.name} attacks for ${damage} damage!`);
            // Apply damage to player (you'll need to implement this in your game state)
            // For now, we'll just log it
            console.log(`Player takes ${damage} damage`);
        } else {
            // 30% chance to use a special ability
            addBattleLog(`${enemy.name} is preparing a special attack!`);
        }

        setPlayerTurn(true);
    }, [enemy, encounterActive, addBattleLog]);

    // Handle player attack
    const handlePlayerAttack = useCallback(() => {
        if (!playerTurn || !encounterActive) return;

        // Simple attack calculation
        const playerDamage = 10 + Math.floor(Math.random() * 20);
        setEnemy((prev) => ({
            ...prev,
            health: Math.max(0, prev.health - playerDamage),
        }));

        addBattleLog(`You attack for ${playerDamage} damage!`);

        if (enemy.health - playerDamage <= 0) {
            // Enemy defeated
            addBattleLog(`${enemy.name} has been defeated!`);
            const creditReward = Math.floor(bribeAmount * 0.5);
            endEncounter('victory', creditReward);
        } else {
            setPlayerTurn(false);
            // Enemy's turn after a short delay
            setTimeout(enemyTurn, 1000);
        }
    }, [
        playerTurn,
        encounterActive,
        enemy.health,
        bribeAmount,
        enemyTurn,
        addBattleLog,
        endEncounter,
    ]);

    // Handle player bribe attempt
    const handleBribe = useCallback(() => {
        if (!playerTurn || !encounterActive || !enemy.isMarketPolice) return;

        if (credits >= bribeAmount) {
            updateCredits(-bribeAmount);
            addBattleLog(`You bribed the ${enemy.name} with ${bribeAmount} credits!`);
            endEncounter('bribed');
        } else {
            addBattleLog(`You don't have enough credits to bribe the ${enemy.name}!`);
            setPlayerTurn(false);
            setTimeout(enemyTurn, 1000);
        }
    }, [
        playerTurn,
        encounterActive,
        enemy,
        credits,
        bribeAmount,
        updateCredits,
        enemyTurn,
        addBattleLog,
        endEncounter,
    ]);

    // Handle player escape attempt
    const handleEscape = useCallback(() => {
        if (!playerTurn || !encounterActive) return;

        const escapeChance = 0.6 - escapeAttempts * 0.1;
        if (Math.random() < escapeChance) {
            addBattleLog('You successfully escaped!');
            endEncounter('escaped');
        } else {
            addBattleLog('Escape failed!');
            setEscapeAttempts((prev) => prev + 1);
            setPlayerTurn(false);
            setTimeout(enemyTurn, 1000);
        }
    }, [playerTurn, encounterActive, escapeAttempts, enemyTurn, addBattleLog, endEncounter]);

    // End the encounter
    const endEncounter = useCallback(
        (outcome, creditChange = 0) => {
            if (creditChange !== 0) {
                updateCredits(creditChange);
                if (creditChange > 0) {
                    addBattleLog(`You received ${creditChange} credits!`);
                }
            }

            setEncounterActive(false);
            setTimeout(() => {
                if (onEncounterEnd) onEncounterEnd(outcome);
            }, 2000);
        },
        [onEncounterEnd, updateCredits, addBattleLog]
    );

    // Update enemy state when enemyData changes
    useEffect(() => {
        if (enemyData) {
            setEnemy((prev) => ({
                ...prev,
                ...enemyData,
                maxHealth: enemyData.maxHealth || enemyData.health || prev.maxHealth || 100,
                health: enemyData.health || prev.health || 100,
            }));
            setEncounterActive(true);
            setBattleLog((prev) => [...prev, `Encountered ${enemyData.name || 'an enemy'}!`]);
            setEscapeAttempts(0);

            // Calculate initial bribe amount if this is a market police encounter
            if (enemyData.isMarketPolice) {
                const bribe = calculateBribeAmount(enemyData.rank || 'D');
                setBribeAmount(bribe);
            }
        } else {
            setEncounterActive(false);
        }
    }, [enemyData, calculateBribeAmount]);

    // Handle player attack
    const handlePlayerAttack = useCallback(() => {
        if (!playerTurn || !encounterActive) return;
        
        // Simple attack calculation
        const playerDamage = 10 + Math.floor(Math.random() * 20);
        setEnemy(prev => ({
            ...prev,
            health: Math.max(0, prev.health - playerDamage)
        }));
        
        addBattleLog(`You attack for ${playerDamage} damage!`);
        
        if (enemy.health - playerDamage <= 0) {
            // Enemy defeated
            addBattleLog(`${enemy.name} has been defeated!`);
            const creditReward = Math.floor(bribeAmount * 0.5);
            endEncounter('victory', creditReward);
        } else {
            setPlayerTurn(false);
            // Enemy's turn after a short delay
            setTimeout(enemyTurn, 1000);
        }
    }, [playerTurn, encounterActive, enemy.health, bribeAmount, enemyTurn, addBattleLog, endEncounter]);
    
    // Handle player bribe attempt
    const handleBribe = useCallback(() => {
        if (!playerTurn || !encounterActive || !enemy.isMarketPolice) return;
        
        if (credits >= bribeAmount) {
            updateCredits(-bribeAmount);
            addBattleLog(`You bribed the ${enemy.name} with ${bribeAmount} credits!`);
            endEncounter('bribed');
        } else {
            addBattleLog(`You don't have enough credits to bribe the ${enemy.name}!`);
            setPlayerTurn(false);
            setTimeout(enemyTurn, 1000);
        }
    }, [playerTurn, encounterActive, enemy, credits, bribeAmount, updateCredits, enemyTurn, addBattleLog, endEncounter]);
    
    // Handle player escape attempt
    const handleEscape = useCallback(() => {
        if (!playerTurn || !encounterActive) return;
        
        const escapeChance = 0.6 - (escapeAttempts * 0.1);
        if (Math.random() < escapeChance) {
            addBattleLog('You successfully escaped!');
            endEncounter('escaped');
        } else {
            addBattleLog('Escape failed!');
            setEscapeAttempts(prev => prev + 1);
            setPlayerTurn(false);
            setTimeout(enemyTurn, 1000);
        }
    }, [playerTurn, encounterActive, escapeAttempts, enemyTurn, addBattleLog, endEncounter]);
    
    // End the encounter
    const endEncounter = useCallback((outcome, creditChange = 0) => {
        if (creditChange !== 0) {
            updateCredits(creditChange);
            if (creditChange > 0) {
                addBattleLog(`You received ${creditChange} credits!`);
            }
        }
        
        setEncounterActive(false);
        setTimeout(() => {
            if (onEncounterEnd) onEncounterEnd(outcome);
        }, 2000);
    }, [onEncounterEnd, updateCredits, addBattleLog]);
    
    // Check for encounter conditions periodically
    useEffect(() => {
        if (!enemyData) {
            const timer = setInterval(() => {
                const reason = checkEncounterConditions();
                if (reason) {
                    triggerMarketPoliceEncounter(reason);
                }
            }, 30000); // Check every 30 seconds
            
            return () => clearInterval(timer);
        }
    }, [enemyData, checkEncounterConditions, triggerMarketPoliceEncounter]);

                case 'random_inspection':
                default:
                    marketPolice = {
                        ...marketPolice,
                        name: 'Market Inspector',
                        health: 180,
                        damage: 15,
                        credits: 200,
                    };
                    addBattleLog('Random inspection initiated by Market Police.');
                    break;
            }

            setEnemy(marketPolice);
            setEncounterActive(true);
            setPlayerTurn(true);
            setBattleLog([]);
            setEscapeAttempts(0);
            setBribeAmount(calculateBribeAmount(marketPolice.rank));
        },
        [addBattleLog, calculateBribeAmount]
    );

    // Check for encounter conditions
    const checkAndTriggerEncounter = useCallback(() => {
        const reason = checkEncounterConditions();
        if (reason && !enemyData) {
            triggerMarketPoliceEncounter(reason);
        }
    }, [checkEncounterConditions, enemyData, triggerMarketPoliceEncounter]);

    useEffect(() => {
        checkAndTriggerEncounter();
    }, [checkAndTriggerEncounter]);

    // Handle Nir Lhat Etol's special interaction
    const handleNirLhatEtolInteraction = useCallback(() => {
        // Check if player has the correct translator
        const hasTranslator = inventory.some(
            (item) => item.itemId === 5 && item.name === 'Universal Translator'
        );

        if (hasTranslator) {
            // Give items to player
            const aiChip = { itemId: 10, name: 'AI Assistant Chip' };
            const nanoVaccine = { itemId: 15, name: 'Nano Vaccine' };
            const quantumLedger = { itemId: 23, name: 'Quantum Ledger Chip' };

            addToInventory(aiChip);
            addToInventory(nanoVaccine);
            addToInventory(quantumLedger);

            // Show message to player
            return (
                <div className="trader-message">
                    <p>
                        "The Galactic Federation is still at war with the cybernetic sprawl. The
                        markets are experiencing wild volatility right now, but be very safe - the
                        area is going to be highly dangerous. Trade at your own risk, friend."
                    </p>
                    <p>
                        "Here, take these items and head to Terra Nexus (galaxyId 11). They might
                        help you on your journey."
                    </p>
                    <p>Received: AI Assistant Chip, Nano Vaccine, and Quantum Ledger Chip</p>
                </div>
            );
        }

        return null;
    }, [addToInventory, inventory]);

    // Handle enemy turn
    const enemyTurn = useCallback(() => {
        if (!enemy.isHostile || enemy.health <= 0 || !encounterActive) {
            setPlayerTurn(true);
            return;
        }

        // Simple AI for enemy actions
        const rand = Math.random();

        if (rand < 0.6) {
            // Basic attack (60% chance)
            const damage = enemy.damage;
            addBattleLog(`${enemy.name} attacks you for ${damage} damage!`);
        } else if (rand < 0.9) {
            // Special ability (30% chance)
            switch (enemy.rank) {
                case 'A':
                    addBattleLog(
                        `${enemy.name} activates Quantum Lockdown! You're stunned for 1 turn!`
                    );
                    break;

                case 'B':
                    addBattleLog(`${enemy.name} calls for backup!`);
                    break;

                default: {
                    const damage = Math.floor(enemy.damage * 1.5);
                    addBattleLog(`${enemy.name} uses a powerful attack for ${damage} damage!`);
                }
            }
        } else {
            // Defensive action (10% chance)
            const healAmount = Math.floor(enemy.maxHealth * 0.15);
            setEnemy((prev) => ({
                ...prev,
                health: Math.min(prev.maxHealth, prev.health + healAmount),
            }));
            addBattleLog(`${enemy.name} uses a repair kit and heals for ${healAmount} HP!`);
        }

        // End enemy turn and return to player
        setPlayerTurn(true);
    }, [enemy, encounterActive, addBattleLog]);

    // Handle player attack
    const handlePlayerAttack = useCallback(() => {
        if (!playerTurn || !encounterActive) return;

        const damage = 20; // Base player damage
        const crit = Math.random() < 0.1; // 10% crit chance
        const totalDamage = crit ? damage * 2 : damage;

        setEnemy((prev) => {
            const newHealth = Math.max(0, prev.health - totalDamage);

            addBattleLog(
                `You attack the ${prev.name} for ${totalDamage}${crit ? ' CRITICAL' : ''} damage!`
            );

            if (newHealth <= 0) {
                addBattleLog(`${prev.name} has been defeated!`);
                endEncounter('defeated', prev.credits);
                return { ...prev, health: 0, isHostile: false };
            }
            return { ...prev, health: newHealth };
        });

        setPlayerTurn(false);
        setTimeout(enemyTurn, 1000); // Enemy gets a turn after a delay
    }, [playerTurn, encounterActive, addBattleLog, endEncounter, enemyTurn]);

    // Handle attempt to bribe
    const handleBribe = () => {
        if (!playerTurn || !encounterActive) return;

        // Check if player has enough credits
        if (credits >= bribeAmount) {
            addBattleLog(`You offer ${bribeAmount} credits to the ${enemy.name}.`);

            // Higher chance of success with higher bribe amount
            const successChance = 0.3 + bribeAmount / (enemy.credits * 2);

            if (Math.random() < successChance) {
                addBattleLog(
                    `The ${enemy.name} accepts your bribe and turns a blind eye... for now.`
                );
                endEncounter('bribed', -bribeAmount);
            } else {
                addBattleLog(`The ${enemy.name} is offended by your bribe attempt!`);
                setPlayerTurn(false);
                setTimeout(enemyTurn, 1000);
            }
        } else {
            addBattleLog("You don't have enough credits for a bribe!");
        }
    };

    // Handle attempt to escape
    const handleEscape = () => {
        if (!playerTurn || !encounterActive) return;

        const stealthItems = inventory.filter((item) => item.tags?.includes('stealth'));
        const quantumProcessors = inventory.filter((item) => item.name === 'Quantum Processor');
        const escapeChance = 0.3 + stealthItems.length * 0.1 + quantumProcessors.length * 0.05;

        addBattleLog('Attempting to escape...');

        if (Math.random() < escapeChance) {
            addBattleLog('You successfully escape from the encounter!');
            endEncounter('escaped');
        } else {
            addBattleLog('Escape failed!');
            setEscapeAttempts((prev) => prev + 1);
            setPlayerTurn(false);
            setTimeout(enemyTurn, 1000);
        }
    };

    // Handle attempt to hack
    const handleHack = () => {
        if (!playerTurn || !encounterActive) return;

        const quantumProcessors = inventory.filter((item) => item.name === 'Quantum Processor');
        const hackPower = quantumProcessors.length * 15; // 15% per quantum processor

        if (quantumProcessors.length === 0) {
            addBattleLog('You need at least one Quantum Processor to attempt a hack!');
            return;
        }

        const newHackProgress = Math.min(100, hackProgress + hackPower);
        setHackProgress(newHackProgress);

        addBattleLog(`Hacking in progress... (${newHackProgress}%)`);

        if (newHackProgress >= 100) {
            addBattleLog('Hack successful! You override the security protocols.');
            endEncounter('hacked');
        } else {
            addBattleLog(`Hack progress: ${newHackProgress}% - Keep going!`);
            setPlayerTurn(false);
            setTimeout(enemyTurn, 1000);
        }
    };

    // End the encounter
    const endEncounter = (outcome, creditChange = 0) => {
        setEncounterActive(false);
        if (onEncounterEnd) {
            onEncounterEnd({
                outcome,
                creditChange,
                enemy: { ...enemy },
            });
        }
    };

    // Special handling for Nir Lhat Etol
    if (enemyData.traderId === 5) {
        return (
            <div className="enemy-container trader-special">{handleNirLhatEtolInteraction()}</div>
        );
    }

    // If no encounter is active, don't render anything
    if (!encounterActive) {
        return null;
    }

    // Apply UI scaling to the container
    const containerStyle = {
        transform: `scale(${uiScaling.scale})`,
        opacity: uiScaling.opacity,
        transformOrigin: 'center',
        transition: `all ${0.3 / uiScaling.animationSpeed}s ease`,
        width: '100%',
        height: '100%',
        display: 'flex',
        justifyContent: 'center',
        alignItems: 'center',
    };

    const textStyle = {
        fontSize: `${uiScaling.fontSize}em`,
        transition: `all ${0.3 / uiScaling.animationSpeed}s ease`,
    };

    return (
        <div className="enemy-encounter-overlay" style={containerStyle}>
            <div className={`enemy-encounter-container ui-tier-${uiTier}`} style={textStyle}>
                <div className="enemy-info">
                    <h2>ENCOUNTER: {enemy.name}</h2>
                    {enemy.reason === 'quantum_processor_limit' && (
                        <p className="encounter-reason">
                            <strong>Charge:</strong> Exceeded legal limit of Quantum Processors
                        </p>
                    )}
                    {enemy.reason === 'illegal_ui_increase' && (
                        <p className="encounter-reason">
                            <strong>Charge:</strong> Unauthorized neural interface modification
                        </p>
                    )}

                    <div className="enemy-stats">
                        <div className="health-bar">
                            <div
                                className="health-fill"
                                style={{
                                    width: `${(enemy.health / (enemy.maxHealth || 1)) * 100}%`,
                                    backgroundColor:
                                        enemy.health < enemy.maxHealth * 0.3
                                            ? '#ff3e3e'
                                            : '#4CAF50',
                                }}
                            ></div>
                            <span>
                                {enemy.health}/{enemy.maxHealth} HP
                            </span>
                        </div>
                        <p>Rank: {enemy.rank}</p>
                        {enemy.statusEffects.length > 0 && (
                            <div className="status-effects">
                                <p>Status: {enemy.statusEffects.join(', ')}</p>
                            </div>
                        )}
                    </div>
                </div>

                <div className="battle-log">
                    <h3>BATTLE LOG</h3>
                    <div className="log-entries">
                        {battleLog.map((entry, index) => (
                            <div key={index} className="log-entry">
                                {entry}
                            </div>
                        ))}
                    </div>
                </div>

                <div className="player-actions">
                    <h3>ACTIONS</h3>
                    <div className="action-buttons">
                        <button
                            onClick={handlePlayerAttack}
                            disabled={!playerTurn || enemy.health <= 0}
                            className="action-btn attack"
                        >
                            ATTACK
                        </button>
                        <button
                            onClick={handleHack}
                            disabled={!playerTurn || enemy.health <= 0}
                            className="action-btn hack"
                        >
                            HACK ({hackProgress}%)
                        </button>
                        <button
                            onClick={handleBribe}
                            disabled={!playerTurn || enemy.health <= 0}
                            className="action-btn bribe"
                        >
                            BRIBE ({bribeAmount} cr)
                        </button>
                        <button
                            onClick={handleEscape}
                            disabled={!playerTurn || escapeAttempts >= 2}
                            className="action-btn escape"
                        >
                            {escapeAttempts >= 2 ? "CAN'T ESCAPE" : 'ESCAPE'}
                        </button>
                    </div>
                </div>
            </div>
        </div>
    );
};

export default Enemy;
